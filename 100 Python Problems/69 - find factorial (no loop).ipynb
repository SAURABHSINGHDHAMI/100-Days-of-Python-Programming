   "source": [
    "Write a function that **accepts** a number and **returns** its **factorial**.\n",
    "\n",
    "You **cannot** use any **loops**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "6bec9e42",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "6"
      ]
     },
     "execution_count": 1,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def fact(number):\n",
    "    if number == 1:\n",
    "        return 1\n",
    "    else:\n",
    "        return number * fact(number-1)\n",
    "\n",
    "result = fact(3)\n",
    "print(result)"
   ]
  }
 ],
