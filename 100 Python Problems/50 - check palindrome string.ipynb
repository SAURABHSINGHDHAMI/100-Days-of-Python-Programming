   "source": [
    "Write a program that can check whether a given **string** is a **palindrome** or not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "8a2f7e51",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your string: palindrome\n",
      "emordnilap\n",
      "Not a palindrome\n"
     ]
    }
   ],
   "source": [
    "a = input('Enter your string: ')\n",
    "\n",
    "rev = ''\n",
    "\n",
    "for i in range(len(a) - 1, -1, -1):\n",
    "    rev = rev + a[i]\n",
    "\n",
    "print(rev)\n",
    "\n",
    "if rev == a:\n",
    "    print('Palindrome')\n",
    "else:\n",
    "    print('Not a palindrome')"
   ]
  }
 ],
