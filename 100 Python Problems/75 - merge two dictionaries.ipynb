   "source": [
    "Write a program to **merge** two given **dictionaries**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b24c72bb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{'a': 2, 'b': 3, 'c': 4, 'd': 5}\n"
     ]
    }
   ],
   "source": [
    "D1 = {'a': 2, 'b': 3}\n",
    "D2 = {'c': 4, 'd': 5}\n",
    "\n",
    "D = {}\n",
    "\n",
    "for i in D1:\n",
    "    D[i] = D1[i]\n",
    "\n",
    "for k in D2:\n",
    "    D[k] = D2[k]\n",
    "\n",
    "print(D)"
   ]
  }
 ],
