   "source": [
    "Write a program to find the **maximum** item in a **list** without using the **max** function."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "18c4ad73",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "9\n"
     ]
    }
   ],
   "source": [
    "L = [2, 3, 5, 6, 8, 9]\n",
    "\n",
    "max = L[0]\n",
    "\n",
    "for i in L:\n",
    "    if i > max:\n",
    "        max = i\n",
    "\n",
    "print(max)"
   ]
  }
 ],
