   "outputs": [],
   "source": [
    "# Write a program to find the sum of first n numbers, where n will be provided by the user.\n",
    "# Eg if the user provides n=10 the output should be 55."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "afeb75a6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your number: 10\n",
      "Your sum is:  55.0\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Enter your number: \"))\n",
    "s = n * (n + 1)/2\n",
    "print(\"Your sum is: \", s)"
   ]
  }
 ],
