   "source": [
    "# Write  a program that will tell whether the given number is divisible by 3 & 6."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "48b5abbc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your number: 12\n",
      "12 is divisible by 3 and 6\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter your number: \"))\n",
    "\n",
    "if num % 3 == 0 and num % 6 ==0:\n",
    "    print(num, \"is divisible by 3 and 6\")\n",
    "else:\n",
    "    print(num, \"is not divisible by 3 and 6\")"
   ]
  }
