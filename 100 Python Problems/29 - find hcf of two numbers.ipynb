   "source": [
    "# User will provide 2 numbers you have to find the HCF of those 2 numbers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "ac15de64",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your first number: 6\n",
      "Enter your second number: 7\n",
      "Your HCF is: 1\n"
     ]
    }
   ],
   "source": [
    "a = int(input('Enter your first number: '))\n",
    "b = int(input('Enter your second number: '))\n",
    "\n",
    "while a % b != 0:\n",
    "    rem = a % b\n",
    "    a = b\n",
    "    b = rem\n",
    "print('Your HCF is:', b)"
   ]
  }
