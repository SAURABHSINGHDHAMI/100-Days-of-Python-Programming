   "source": [
    "Write a program that can **create** a **new list** from a **given list**, where each item in the new list is the **square** of the corresponding item in the old list."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b8f9d4f6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[4, 9, 16, 25, 36]\n"
     ]
    }
   ],
   "source": [
    "L1 = [2, 3, 4, 5, 6]\n",
    "\n",
    "L2 = []\n",
    "\n",
    "for i in L1:\n",
    "    L2.append(i**2)\n",
    "\n",
    "print(L2)"
   ]
  }
