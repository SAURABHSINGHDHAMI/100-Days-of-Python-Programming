   ],
   "source": [
    "counter = 0\n",
    "\n",
    "num = 2\n",
    "\n",
    "while counter <= 25:\n",
    "    for i in range(2, num):\n",
    "        if num % i == 0:\n",
    "            break\n",
    "    else:\n",
    "        print(num)\n",
    "        \n",
    "        counter = counter + 1\n",
    "    \n",
    "    num = num + 1"
   ]
  }
