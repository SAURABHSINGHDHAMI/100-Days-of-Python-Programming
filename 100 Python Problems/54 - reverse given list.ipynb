   ],
   "source": [
    "L = [1, 2, 3, 4, 5]\n",
    "\n",
    "rev = []\n",
    "\n",
    "for i in range(len(L) - 1, -1, -1):\n",
    "    rev.append(L[i])\n",
    "\n",
    "print(rev)"
   ]
  }
