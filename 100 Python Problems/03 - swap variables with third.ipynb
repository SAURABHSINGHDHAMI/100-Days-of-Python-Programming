   "source": [
    "The user will input **two** numbers. Write a program to **swap** the numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2c5b890d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter the value of a : 10\n",
      "Enter the value of b: 20\n",
      "value of a:  20\n",
      "value of b:  10\n"
     ]
    }
   ],
   "source": [
    "a = int(input(\"Enter the value of a : \"))\n",
    "\n",
    "b = int(input(\"Enter the value of b: \"))\n",
    "\n",
    "temp = a\n",
    "a = b\n",
    "b = temp\n",
    "\n",
    "print(\"value of a: \", a)\n",
    "print(\"value of b: \", b)"
   ]
  }
 ],
