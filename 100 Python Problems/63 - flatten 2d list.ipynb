   "source": [
    "Write a program that can **convert** a **2D list** to a **1D list**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "f5a093f7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 2, 3, 4, 5, 7, 8]\n"
     ]
    }
   ],
   "source": [
    "L = [1, 2, 3, 4, [5, 7, 8]]\n",
    "\n",
    "rev = []\n",
    "\n",
    "for i in L:\n",
    "    if type(i) == list:\n",
    "        rev.extend(i)\n",
    "    else:\n",
    "        rev.append(i)\n",
    "\n",
    "print(rev)"
   ]
  }
 ],
