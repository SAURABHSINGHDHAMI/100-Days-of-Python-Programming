   "id": "8302a5c4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 2, 3, 4, 5, 6, 7, 8]\n"
     ]
    }
   ],
   "source": [
    "L1 = [1, 2, 3, 4]\n",
    "L2 = [5, 6, 7, 8]\n",
    "L = []\n",
    "for i in L1:\n",
    "    L.append(i)\n",
    "for j in L2:\n",
    "    L.append(j)\n",
    "print(L)"
   ]
  }
