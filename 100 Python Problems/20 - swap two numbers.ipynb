   "outputs": [],
   "source": [
    "# Write a program that will swap numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "63acb5f6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your first number: 7\n",
      "Enter your second number: 3\n",
      "after swapping: \n",
      "your a is:  3\n",
      "your b is:  7\n"
     ]
    }
   ],
   "source": [
    "a = int(input(\"Enter your first number: \"))\n",
    "b = int(input(\"Enter your second number: \"))\n",
    "\n",
    "a = a + b\n",
    "b = a - b\n",
    "a = a - b\n",
    "\n",
    "print(\"after swapping: \")\n",
    "print(\"your a is: \", a)\n",
    "print(\"your b is: \", b)"
   ]
  }
 ],
