   "source": [
    "Write a python program to convert a string to title case without using the title()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0d0d4ac2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "['hEllO', 'sAuRABh', 'SinGH', 'dHaMI']\n",
      "Hello Saurabh Singh Dhami \n"
     ]
    }
   ],
   "source": [
    "a = 'hEllO sAuRABh SinGH dHaMI'\n",
    "y = a.split()\n",
    "print(y)\n",
    "r = ''\n",
    "\n",
    "for i in y:\n",
    "    r = r + i[0].upper() + i[1:].lower() + ' '\n",
    "print(r)"
   ]
  }
