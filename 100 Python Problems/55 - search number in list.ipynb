   "source": [
    "Write a program to **search** for a given number in a **list**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "a2307186",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your number: 0\n",
      "False\n"
     ]
    }
   ],
   "source": [
    "L = [1, 2, 3, 4, 5, 6, 7, 8, 9]\n",
    "\n",
    "num = int(input('Enter your number: '))\n",
    "\n",
    "for i in L:\n",
    "    if i == num:\n",
    "        print('True')\n",
    "        break\n",
    "else:\n",
    "    print('False')"
   ]
  }
 ],
