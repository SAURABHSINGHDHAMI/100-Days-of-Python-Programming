   "source": [
    "Print all the **Armstrong numbers** in the range of **100** to **1000**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0609ff26",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "153\n",
      "370\n",
      "371\n",
      "407\n"
     ]
    }
   ],
   "source": [
    "for num in range(100, 1000):\n",
    "    \n",
    "    i = num\n",
    "    \n",
    "    a = num % 10\n",
    "    \n",
    "    num = num // 10\n",
    "    b = num % 10\n",
    "    \n",
    "    c = num // 10\n",
    "    \n",
    "    if (a**3) + (b**3) + (c**3) == i:\n",
    "        print(i)\n",
    "    \n",
    "    i = i + 1"
   ]
  }
 ],
