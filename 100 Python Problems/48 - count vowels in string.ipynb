   "source": [
    "Count the number of vowels in a string provided by the user."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "8d847e2b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your string: hello saurabh singh dhami\n",
      "8\n"
     ]
    }
   ],
   "source": [
    "a = input('Enter your string: ')\n",
    "vowels = 'aeiou'\n",
    "count = 0\n",
    "\n",
    "for i in a:\n",
    "    if i in vowels:\n",
    "        count = count + 1\n",
    "print(count)"
   ]
  }
