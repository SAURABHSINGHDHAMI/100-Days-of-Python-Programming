   "source": [
    "Write a program that will give you the **sum** of **three** digits."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "c5c80a4b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter the three digit number: 123\n",
      "6\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter the three-digit number: \"))\n",
    "\n",
    "a = num % 10  # (123 % 10 = 3)\n",
    "\n",
    "num = num // 10  # (123 // 10 = 12)\n",
    "\n",
    "b = num % 10  # (12 % 10 = 2)\n",
    "\n",
    "c = num // 10  # (12 // 10 = 1)\n",
    "\n",
    "rev = (a + b + c)\n",
    "\n",
    "print(rev)"
   ]
  }
 ],
