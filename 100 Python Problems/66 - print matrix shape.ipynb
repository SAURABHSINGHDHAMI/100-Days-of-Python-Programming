   "source": [
    "Write a program to print the **shape of a matrix**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "67be5ea2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The shape of this matrix is: 3 * 3\n"
     ]
    }
   ],
   "source": [
    "matrix = [\n",
    "    [1, 2, 3],\n",
    "    [4, 5, 6],\n",
    "    [7, 8, 9]\n",
    "]\n",
    "\n",
    "row = 0\n",
    "\n",
    "for i in matrix:\n",
    "    row = row + 1\n",
    "\n",
    "print('The shape of this matrix is:', row, '*', len(i))"
   ]
  }
 ],
