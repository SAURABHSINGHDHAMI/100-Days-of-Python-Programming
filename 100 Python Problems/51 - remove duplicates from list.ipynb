   "source": [
    "Write a program to **remove** all **duplicates** from a **list**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "affabd50",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 2, 3, 4, 5, 6, 7]\n"
     ]
    }
   ],
   "source": [
    "L1 = [1, 2, 2, 3, 4, 4, 5, 6, 7, 7]\n",
    "\n",
    "L2 = []\n",
    "\n",
    "for i in L1:\n",
    "    if i not in L2:\n",
    "        L2.append(i)\n",
    "\n",
    "print(L2)"
   ]
  }
 ],
