      "Enter the value of the character: 4\n",
      "sauabh\n"
     ]
    }
   ],
   "source": [
    "a = input('Enter your string: ')\n",
    "b = int(input('Enter the value of the character: '))\n",
    "\n",
    "c = a[0:b - 1]\n",
    "d = a[b:]\n",
    "print(c + d)"
