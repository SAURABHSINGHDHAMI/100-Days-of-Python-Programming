   ],
   "source": [
    "count = 0\n",
    "a = 0\n",
    "b = 1\n",
    "\n",
    "print(a)\n",
    "print(b)\n",
    "\n",
    "while True:\n",
    "    c = a + b\n",
    "\n",
    "    a = b\n",
    "    b = c\n",
    "\n",
    "    print(c)\n",
    "\n",
    "    count = count + 1\n",
    "\n",
    "    if count == 18:\n",
    "        break"
   ]
  }
