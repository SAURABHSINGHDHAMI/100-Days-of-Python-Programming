   "source": [
    "Write a program to **check** whether a **list** is in **ascending order** or not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "be8c6f4e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Not sorted\n"
     ]
    }
   ],
   "source": [
    "L = [2, 3, 1, 6, 0]\n",
    "\n",
    "flag = 0\n",
    "\n",
    "for i in range(0, len(L)-1):\n",
    "    if L[i] >= L[i+1]:\n",
    "        flag = 1\n",
    "        break\n",
    "\n",
    "if flag == 0:\n",
    "    print('Sorted')\n",
    "else:\n",
    "    print('Not sorted')"
   ]
  }
 ],
