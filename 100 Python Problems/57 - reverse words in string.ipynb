   "source": [
    "Write a program that can reverse words of a given string.\n",
    "\n",
    "Eg if the input is Hello how are you\n",
    "\n",
    "Output should be you are how Hello"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "470bdfe8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Enter your string: hello saurabh singh dhami\n",
      "dhami singh saurabh hello\n"
     ]
    }
   ],
   "source": [
    "a = input('Enter your string: ')\n",
    "x = a.split()\n",
    "rev = []\n",
    "\n",
    "for i in range(len(x)-1, -1, -1):\n",
    "    rev.append(x[i])\n",
    "y = ' '.join(rev)\n",
    "print(y)"
   ]
  }
 ],
